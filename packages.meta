{
  "names": {
    "fastrtps": {
      "cmake-args": [
        "-DSECURITY=OFF",
        "-DCMAKE_DISABLE_FIND_PACKAGE_OpenSSL=ON",
        "-DTHIRDPARTY=ON"
      ]
    },
    "lttngpy": {
      "cmake-args": ["-DBUILD_TESTING=OFF"]
    },
    "cyclonedds": {
      "cmake-args": [
        "-DENABLE_SECURITY=OFF",
        "-DCMAKE_DISABLE_FIND_PACKAGE_OpenSSL=ON"
      ]
    }
  }
}